---
// Renders an ArcGIS map for a project. Three modes, in priority order:
//   1. `webmapId`: a public ArcGIS web map item id. Rendered with the modern
//      ArcGIS Maps SDK for JavaScript (4.x), the same engine as the new Map
//      Viewer, so new-style renderers/symbology display correctly. (The classic
//      apps/Embed iframe uses the old 3.x API and mis-renders v2.x web maps.)
//   2. `src`: a full iframe URL (StoryMaps, Experience Builder, web scenes).
//   3. neither: a labeled placeholder.
const ARCGIS_VERSION = "4.30";
interface Props {
  webmapId?: string;
  src?: string;
  mapLink?: string;
  title: string;
}
const { webmapId, src, mapLink, title } = Astro.props;
---

{
  webmapId ? (
    <div class="map-frame">
      <div
        class="arcgis-view"
        data-webmap-id={webmapId}
        role="application"
        aria-label={`Interactive map: ${title}`}
      />
      <div class="map-loading" aria-hidden="true">
        <span class="spinner" />
        <span class="map-loading-text">Loading interactive map…</span>
      </div>
    </div>
    <link rel="stylesheet" href={`https://js.arcgis.com/${ARCGIS_VERSION}/esri/themes/dark/main.css`} />
    <script src={`https://js.arcgis.com/${ARCGIS_VERSION}/`} is:inline />
    <script is:inline>
      (function () {
        function init() {
          if (!window.require) return;
          document.querySelectorAll(".arcgis-view[data-webmap-id]").forEach(function (el) {
            if (el.dataset.inited) return;
            el.dataset.inited = "1";
            var loading = el.parentNode.querySelector(".map-loading");
            window.require(
              ["esri/WebMap", "esri/views/MapView", "esri/core/reactiveUtils"],
              function (WebMap, MapView, reactiveUtils) {
                var map = new WebMap({ portalItem: { id: el.dataset.webmapId } });
                var view = new MapView({ container: el, map: map });
                view
                  .when(function () {
                    // Hide the loader once the view has drawn and layers finish updating.
                    return reactiveUtils.whenOnce(function () {
                      return !view.updating;
                    });
                  })
                  .then(function () {
                    if (loading) loading.classList.add("is-hidden");
                  })
                  .catch(function () {
                    if (loading) loading.classList.add("is-hidden");
                  });
              }
            );
          });
        }
        if (window.require) init();
        else window.addEventListener("load", init);
      })();
    </script>
  ) : src ? (
    <div class="map-frame">
      <iframe
        src={src}
        title={`Interactive map: ${title}`}
        loading="lazy"
        allowfullscreen
        referrerpolicy="strict-origin-when-cross-origin"
      />
    </div>
  ) : mapLink ? (
    <div class="map-linkout">
      <div class="grid-bg" aria-hidden="true"></div>
      <div class="ph-content">
        <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 18l-6 3V6l6-3 6 3 6-3v15l-6 3-6-3Z" />
          <path d="M9 3v15M15 6v15" />
        </svg>
        <p class="ph-title">Interactive map</p>
        <p class="ph-sub">This map is data-heavy, so it opens full-screen on ArcGIS.</p>
        <a class="map-link-btn" href={mapLink} target="_blank" rel="noopener">
          Open interactive map ↗
        </a>
      </div>
    </div>
  ) : (
    <div class="map-placeholder" role="img" aria-label={`Map placeholder for ${title}`}>
      <div class="grid-bg" aria-hidden="true"></div>
      <div class="ph-content">
        <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 18l-6 3V6l6-3 6 3 6-3v15l-6 3-6-3Z" />
          <path d="M9 3v15M15 6v15" />
        </svg>
        <p class="ph-title">Interactive map</p>
        <p class="ph-sub">An ArcGIS web map will be embedded here.</p>
      </div>
    </div>
  )
}

<style>
  .map-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-strong);
    background: var(--bg-elev);
  }
  .map-frame iframe,
  .map-frame .arcgis-view {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .map-loading {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    background: var(--bg-elev);
    color: var(--text-muted);
    font-size: 0.9rem;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  .map-loading.is-hidden {
    opacity: 0;
  }
  .spinner {
    width: 30px;
    height: 30px;
    border: 2px solid var(--border-strong);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: map-spin 0.8s linear infinite;
  }
  @keyframes map-spin {
    to {
      transform: rotate(360deg);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .spinner {
      animation-duration: 2s;
    }
  }
  .map-placeholder,
  .map-linkout {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px dashed var(--border-strong);
    background: var(--bg-elev);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .map-link-btn {
    display: inline-block;
    margin-top: 1.1rem;
    font-size: 0.92rem;
    font-weight: 500;
    padding: 0.6rem 1.2rem;
    border-radius: var(--radius);
    border: 1px solid var(--border-strong);
    color: var(--accent);
    background: rgba(93, 202, 165, 0.08);
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  .map-link-btn:hover {
    background: rgba(93, 202, 165, 0.16);
    border-color: var(--accent);
  }
  .grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid) 1px, transparent 1px);
    background-size: 32px 32px;
  }
  .ph-content {
    position: relative;
    text-align: center;
    color: var(--accent);
    padding: 1rem;
  }
  .ph-title {
    margin: 0.8rem 0 0.2rem;
    font-weight: 600;
    color: var(--text);
  }
  .ph-sub {
    margin: 0;
    font-size: 0.88rem;
    color: var(--text-muted);
  }
</style>
