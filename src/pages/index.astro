---
import Base from "../layouts/Base.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { site, skills, experience, education, leadership } from "../data/site";
import { featuredProjects, otherProjects } from "../data/projects";
---

<Base>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="container hero-inner">
      <p class="eyebrow">{site.status}</p>
      <h1 class="hero-title">{site.name}</h1>
      <p class="hero-role">{site.tagline}</p>
      <p class="hero-intro">{site.intro}</p>
      <div class="hero-actions">
        <a href={site.resume} class="button primary">Resume</a>
        <a href="#about" class="button">Skills</a>
        <a href={`mailto:${site.email}`} class="button">Get in touch</a>
      </div>
    </div>
  </section>

  <!-- Work -->
  <section id="work" class="section">
    <div class="container">
      <p class="eyebrow">Selected work</p>
      <h2 class="section-title">Spatial analysis & GIS projects</h2>
      <div class="grid">
        {featuredProjects.slice(0, 6).map((project) => <ProjectCard project={project} />)}
      </div>

      <div id="more-projects" class="more-projects" hidden>
        {featuredProjects.length > 6 && (
          <div class="grid more-grid">
            {featuredProjects.slice(6).map((project) => <ProjectCard project={project} />)}
          </div>
        )}
        <h3 class="subhead">Other projects</h3>
        <div class="grid">
          {otherProjects.map((project) => <ProjectCard project={project} />)}
        </div>
      </div>

      <div class="see-more-wrap">
        <button
          class="button see-more"
          type="button"
          aria-expanded="false"
          aria-controls="more-projects"
        >
          See more projects
        </button>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var btn = document.querySelector(".see-more");
      var more = document.getElementById("more-projects");
      if (!btn || !more) return;
      btn.addEventListener("click", function () {
        var hidden = more.hasAttribute("hidden");
        if (hidden) {
          more.removeAttribute("hidden");
          btn.textContent = "Show fewer projects";
          btn.setAttribute("aria-expanded", "true");
        } else {
          more.setAttribute("hidden", "");
          btn.textContent = "See more projects";
          btn.setAttribute("aria-expanded", "false");
          document.getElementById("work").scrollIntoView({ behavior: "smooth" });
        }
      });
    })();
  </script>

  <!-- About -->
  <section id="about" class="section">
    <div class="container">
      <div class="about-layout">
        <div>
          <p class="eyebrow">About</p>
          <h2 class="section-title">A little background</h2>
          <p>
            I started writing software in middle school and competed in the FIRST Robotics
            Competition in high school, where I picked up Java and object-oriented programming.
            Today I’m an honors computer science student at the University of Houston, with minors
            in Architecture and Data &amp; Society, and I recently spent a semester studying at the
            Vrije Universiteit Amsterdam.
          </p>
          <p>
            My focus has grown toward geographic information systems and urban planning, using
            spatial data and visualization to understand transit, land use, and equity in cities,
            with the goal of pursuing urban planning in graduate school and beyond.
          </p>
          <p>When I’m not working, you can usually find me riding my bike, reading, or playing cello.</p>
        </div>
        <aside class="about-side">
          <div class="panel">
            <h3 class="panel-title">Education</h3>
            {education.map((ed) => (
              <div class="edu">
                <p class="edu-org">{ed.org}</p>
                <p class="edu-detail">{ed.detail}</p>
                <p class="edu-meta">{ed.dates}{ed.note ? ` · ${ed.note}` : ""}</p>
              </div>
            ))}
          </div>
        </aside>
      </div>

      <div class="panel skills-panel">
        <h3 class="panel-title">Skills</h3>
        <div class="skill-grid">
          {skills.map((group) => (
            <div class="skill-group">
              <p class="skill-label">{group.label}</p>
              <ul class="skill-list">
                {group.items.map((item) => <li class="tag">{item}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Experience -->
  <section id="experience" class="section">
    <div class="container">
      <p class="eyebrow">Experience</p>
      <h2 class="section-title">Where I’ve worked</h2>
      <ul class="timeline">
        {experience.map((job) => (
          <li class="job">
            <div class="job-head">
              <div>
                <span class="job-role">{job.role}</span>
                <span class="job-org">{job.org}</span>
              </div>
              <span class="job-dates">{job.dates}</span>
            </div>
            <ul class="job-notes">
              {job.notes.map((n) => <li>{n}</li>)}
            </ul>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Leadership -->
  <section id="leadership" class="section">
    <div class="container">
      <p class="eyebrow">Leadership & extracurricular</p>
      <h2 class="section-title">What I’m involved in</h2>
      <ul class="lead-list">
        {leadership.map((item) => (
          <li class="lead-item">
            <div class="lead-head">
              <span class="lead-role">{item.role}</span>
              <span class="lead-dates">{item.dates}</span>
            </div>
            <p class="lead-org">{item.org}</p>
            <p class="lead-note">{item.note}</p>
            {item.link && (
              <a class="lead-link" href={item.link.href} target="_blank" rel="noopener">
                {item.link.label} ↗
              </a>
            )}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="section contact">
    <div class="container contact-inner">
      <p class="eyebrow">Contact</p>
      <h2 class="section-title">Let’s talk</h2>
      <p class="contact-text">
        I’m always glad to talk about cities, maps, and data. The best way to reach me is email.
      </p>
      <div class="hero-actions">
        <a href={`mailto:${site.email}`} class="button primary">{site.email}</a>
        <a href={site.links.linkedin} target="_blank" rel="noopener" class="button">LinkedIn</a>
        <a href={site.links.github} target="_blank" rel="noopener" class="button">GitHub</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-top: clamp(3.5rem, 9vw, 6.5rem);
    padding-bottom: clamp(2.5rem, 4vw, 3.5rem);
    border-bottom: 1px solid var(--border);
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid) 1px, transparent 1px);
    background-size: 38px 38px;
    mask-image: radial-gradient(ellipse 80% 70% at 30% 0%, #000 40%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 30% 0%, #000 40%, transparent 100%);
  }
  .hero-inner {
    position: relative;
  }
  .hero-title {
    font-size: clamp(2.8rem, 9vw, 5.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    margin: 0 0 0.6rem;
    line-height: 1.02;
  }
  .hero-role {
    font-size: clamp(1.05rem, 2.2vw, 1.5rem);
    color: var(--text);
    font-weight: 500;
    margin: 0 0 1.6rem;
  }
  .hero-intro {
    font-size: clamp(1.02rem, 1.6vw, 1.22rem);
    color: var(--text-muted);
    max-width: 60ch;
    margin: 0 0 2rem;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 1.2rem;
  }
  .subhead {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin: 3rem 0 1.3rem;
    font-weight: 500;
  }
  .more-grid {
    margin-top: 1.2rem;
  }
  .see-more-wrap {
    display: flex;
    justify-content: center;
    margin-top: 2rem;
  }
  .see-more {
    cursor: pointer;
    font-family: inherit;
  }

  .about-layout {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  .about-layout p {
    color: var(--text-muted);
  }
  .about-side {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .panel {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }
  .panel-title {
    font-size: 1rem;
    margin: 0 0 1.1rem;
  }
  .skills-panel {
    margin-top: 2rem;
  }
  .skill-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1.5rem 2rem;
    margin-top: 0.3rem;
  }
  .skill-group {
    margin-bottom: 0;
  }
  .skill-label {
    font-size: 0.78rem;
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.55rem;
  }
  .skill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .edu {
    margin-bottom: 1rem;
  }
  .edu:last-child {
    margin-bottom: 0;
  }
  .edu-org {
    margin: 0;
    font-weight: 500;
  }
  .edu-detail {
    margin: 0.1rem 0;
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  .edu-meta {
    margin: 0;
    font-size: 0.82rem;
    color: var(--text-faint);
    font-family: var(--font-mono);
  }

  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }
  .job {
    border-left: 2px solid var(--border-strong);
    padding-left: 1.4rem;
  }
  .job-head {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
  }
  .job-role {
    font-weight: 600;
  }
  .job-org {
    color: var(--accent);
    margin-left: 0.6rem;
    font-size: 0.95rem;
  }
  .job-dates {
    color: var(--text-faint);
    font-size: 0.84rem;
    font-family: var(--font-mono);
  }
  .job-notes {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .job-notes li {
    margin-bottom: 0.25rem;
  }

  .lead-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.2rem;
  }
  .lead-item {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.4rem;
  }
  .lead-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.2rem;
  }
  .lead-role {
    font-weight: 600;
  }
  .lead-dates {
    color: var(--text-faint);
    font-size: 0.82rem;
    font-family: var(--font-mono);
    white-space: nowrap;
  }
  .lead-org {
    color: var(--accent);
    font-size: 0.92rem;
    margin: 0 0 0.6rem;
  }
  .lead-note {
    color: var(--text-muted);
    font-size: 0.94rem;
    margin: 0;
  }
  .lead-link {
    display: inline-block;
    margin-top: 0.7rem;
    font-size: 0.86rem;
    font-weight: 500;
    color: var(--accent);
  }
  .lead-link:hover {
    color: #8fe0c5;
  }

  .contact-inner {
    text-align: center;
  }
  .contact-inner .eyebrow {
    margin-inline: auto;
  }
  .contact-text {
    color: var(--text-muted);
    max-width: 46ch;
    margin: 0 auto 2rem;
  }
  .contact-inner .hero-actions {
    justify-content: center;
  }

  @media (max-width: 820px) {
    .about-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
