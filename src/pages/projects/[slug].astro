---
import Base from "../../layouts/Base.astro";
import MapEmbed from "../../components/MapEmbed.astro";
import { projects } from "../../data/projects";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const showMap = project.featured;
---

<Base title={project.title} description={project.summary}>
  <article class="project">
    <div class="container">
      <a href="/#work" class="back">← All work</a>

      <header class="proj-head">
        <div class="meta">
          <span class="tool">{project.tool}</span>
          <span class="date">{project.date}</span>
        </div>
        <h1 class="proj-title">{project.title}</h1>
        <p class="lede">{project.summary}</p>
        <ul class="tags">
          {project.tags.map((t) => <li class="tag">{t}</li>)}
        </ul>
      </header>

      {showMap && (
        <div class="map-wrap">
          <MapEmbed webmapId={project.webmapId} src={project.mapEmbed} mapLink={project.mapLink} title={project.title} />
        </div>
      )}

      <div class="body">
        <div class="prose">
          <p>{project.description}</p>
          <h2>Highlights</h2>
          <ul class="highlights">
            {project.highlights.map((h) => <li>{h}</li>)}
          </ul>
          {project.link && (
            <p class="ext">
              <a href={project.link.href} target="_blank" rel="noopener" class="button">
                {project.link.label} ↗
              </a>
            </p>
          )}
        </div>

        {project.stat && (
          <aside class="stat-panel">
            <span class="big">{project.stat.value}</span>
            <span class="lbl">{project.stat.label}</span>
          </aside>
        )}
      </div>
    </div>
  </article>
</Base>

<style>
  .project {
    padding-block: 3rem 4rem;
  }
  .back {
    display: inline-block;
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }
  .back:hover {
    color: var(--accent);
  }
  .proj-head {
    max-width: 70ch;
    margin-bottom: 2.5rem;
  }
  .meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 0.9rem;
  }
  .tool {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 500;
  }
  .date {
    color: var(--text-faint);
    font-size: 0.85rem;
  }
  .proj-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    margin: 0 0 1rem;
  }
  .lede {
    font-size: 1.15rem;
    color: var(--text-muted);
    margin: 0 0 1.2rem;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .map-wrap {
    margin-bottom: 3rem;
  }
  .body {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 2.5rem;
    align-items: start;
  }
  .prose {
    max-width: 70ch;
  }
  .prose p {
    color: var(--text-muted);
    font-size: 1.05rem;
  }
  .prose h2 {
    font-size: 1.25rem;
    margin: 2rem 0 1rem;
  }
  .highlights {
    padding-left: 1.2rem;
    color: var(--text-muted);
  }
  .highlights li {
    margin-bottom: 0.6rem;
  }
  .ext {
    margin-top: 2rem;
  }
  .stat-panel {
    background: rgba(93, 202, 165, 0.07);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.6rem;
    text-align: center;
    position: sticky;
    top: 88px;
  }
  .big {
    display: block;
    font-size: 2.6rem;
    font-weight: 600;
    color: var(--accent);
    font-family: var(--font-mono);
    line-height: 1;
  }
  .lbl {
    display: block;
    margin-top: 0.7rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  @media (max-width: 760px) {
    .body {
      grid-template-columns: 1fr;
    }
    .stat-panel {
      position: static;
    }
  }
</style>
