---
import Base from "../../layouts/Base.astro";
import MapEmbed from "../../components/MapEmbed.astro";
import { projects } from "../../data/projects";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const hasImages = !!(project.images && project.images.length);
// Tall (portrait) images render beside the text to cut dead vertical space.
const asideLayout = hasImages && !!project.imageAside;
// Show the map area only when there's an actual map source to render, so projects
// awaiting a link (or whose deliverable isn't a web map) don't show an empty slot.
// Images take precedence over a live map when both exist.
const showMap = !hasImages && !!(project.webmapId || project.mapEmbed || project.mapLink);
---

<Base title={project.title} description={project.summary}>
  <article class="project">
    <div class="container">
      <a href="/#work" class="back">← All work</a>

      <header class="proj-head">
        <div class="meta">
          <span class="tool">{project.tool}</span>
          <span class="date">{project.date}</span>
        </div>
        <h1 class="proj-title">{project.title}</h1>
        <p class="lede">{project.summary}</p>
        {project.award && <p class="award">★ {project.award}</p>}
        <ul class="tags">
          {project.tags.map((t) => <li class="tag">{t}</li>)}
        </ul>
      </header>

      {asideLayout ? (
        <div class="split">
          <div class="split-media">
            {project.images!.map((img) => (
              <img src={img.src} alt={img.alt} loading="lazy" />
            ))}
          </div>
          <div class="split-text">
            <p>{project.description}</p>
            <h2>Highlights</h2>
            <ul class="highlights">
              {project.highlights.map((h) => <li>{h}</li>)}
            </ul>
            {project.stat && (
              <div class="stat-inline">
                <span class="siv">{project.stat.value}</span>
                <span class="sil">{project.stat.label}</span>
              </div>
            )}
            {project.link && (
              <p class="ext">
                <a href={project.link.href} target="_blank" rel="noopener" class="button">
                  {project.link.label} ↗
                </a>
              </p>
            )}
          </div>
        </div>
      ) : (
        <>
          {hasImages && (
            <div class={`gallery${project.images!.length === 1 ? " gallery-single" : ""}${project.images!.length === 2 ? " gallery-stack" : ""}`}>
              {project.images!.map((img) => (
                <img src={img.src} alt={img.alt} loading="lazy" />
              ))}
            </div>
          )}

          {showMap && (
            <div class="map-wrap">
              <MapEmbed webmapId={project.webmapId} src={project.mapEmbed} mapLink={project.mapLink} title={project.title} />
            </div>
          )}

          <div class="body">
            <div class="prose">
              <p>{project.description}</p>
              <h2>Highlights</h2>
              <ul class="highlights">
                {project.highlights.map((h) => <li>{h}</li>)}
              </ul>
              {project.link && (
                <p class="ext">
                  <a href={project.link.href} target="_blank" rel="noopener" class="button">
                    {project.link.label} ↗
                  </a>
                </p>
              )}
            </div>

            {project.stat && (
              <aside class="stat-panel">
                <span class="big">{project.stat.value}</span>
                <span class="lbl">{project.stat.label}</span>
              </aside>
            )}
          </div>
        </>
      )}
    </div>
  </article>
</Base>

<style>
  .project {
    padding-block: 3rem 4rem;
  }
  .back {
    display: inline-block;
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }
  .back:hover {
    color: var(--accent);
  }
  .proj-head {
    max-width: 70ch;
    margin-bottom: 2.5rem;
  }
  .meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 0.9rem;
  }
  .tool {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 500;
  }
  .date {
    color: var(--text-faint);
    font-size: 0.85rem;
  }
  .proj-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    margin: 0 0 1rem;
  }
  .lede {
    font-size: 1.15rem;
    color: var(--text-muted);
    margin: 0 0 1.2rem;
  }
  .award {
    display: inline-block;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--accent);
    background: rgba(93, 202, 165, 0.1);
    border: 1px solid var(--border-strong);
    border-radius: 100px;
    padding: 4px 12px;
    margin: 0 0 1.2rem;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .map-wrap {
    margin-bottom: 3rem;
  }
  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) 1fr;
    gap: 2.5rem;
    align-items: start;
    margin-bottom: 1.5rem;
  }
  .split-media img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    position: sticky;
    top: 88px;
  }
  .split-text p {
    color: var(--text-muted);
    font-size: 1.05rem;
  }
  .split-text h2 {
    font-size: 1.25rem;
    margin: 1.75rem 0 1rem;
  }
  .stat-inline {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin: 1.75rem 0;
    padding: 0.85rem 1rem;
    background: rgba(93, 202, 165, 0.07);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .siv {
    flex-shrink: 0;
    font-size: 1.6rem;
    font-weight: 600;
    line-height: 1;
    color: var(--accent);
    font-family: var(--font-mono);
  }
  .sil {
    padding-left: 0.85rem;
    border-left: 1px solid var(--border-strong);
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.35;
  }
  @media (max-width: 760px) {
    .split {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .split-media img {
      position: static;
      width: auto;
      max-width: 100%;
      max-height: 460px;
      margin-inline: auto;
      display: block;
    }
  }
  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
    align-items: start;
  }
  .gallery.gallery-single {
    display: flex;
    justify-content: center;
  }
  /* Two wide images stack full-width (rather than shrinking side by side). */
  .gallery.gallery-stack {
    grid-template-columns: 1fr;
    max-width: 1000px;
    margin-inline: auto;
  }
  .gallery img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
  }
  /* A lone image is centered and height-capped so tall maps don't dominate. */
  .gallery.gallery-single img {
    width: auto;
    max-width: 100%;
    max-height: 560px;
  }
  .body {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 2.5rem;
    align-items: start;
  }
  .prose {
    max-width: 70ch;
  }
  .prose p {
    color: var(--text-muted);
    font-size: 1.05rem;
  }
  .prose h2 {
    font-size: 1.25rem;
    margin: 2rem 0 1rem;
  }
  .highlights {
    padding-left: 1.2rem;
    color: var(--text-muted);
  }
  .highlights li {
    margin-bottom: 0.6rem;
  }
  .ext {
    margin-top: 2rem;
  }
  .stat-panel {
    background: rgba(93, 202, 165, 0.07);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.6rem;
    text-align: center;
    position: sticky;
    top: 88px;
  }
  .big {
    display: block;
    font-size: 2.6rem;
    font-weight: 600;
    color: var(--accent);
    font-family: var(--font-mono);
    line-height: 1;
  }
  .lbl {
    display: block;
    margin-top: 0.7rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  @media (max-width: 760px) {
    .body {
      grid-template-columns: 1fr;
    }
    .stat-panel {
      position: static;
    }
  }
</style>
